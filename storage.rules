rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Classroom notes — authenticated users can read; teachers can write
    match /classrooms/{classId}/notes/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024
                   && request.resource.contentType.matches('application/pdf|image/png|image/jpeg');
    }

    // Fallback: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
